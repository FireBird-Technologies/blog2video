    "data_visualisation": {
      "label": "Data Visualisation",
      "defaults": {
        "titleFontSize": {
          "portrait": 69,
          "landscape": 55
        },
        "descriptionFontSize": {
          "portrait": 33,
          "landscape": 26
        },
        "chartType": "line",
        "chartSummary": "Readings rise through the period before settling back from the peak.",
        "chartTable": {
          "headers": [
            "Period",
            "Index",
            "Prior"
          ],
          "rows": [
            [
              "Q1",
              "298",
              "272"
            ],
            [
              "Q2",
              "308",
              "268"
            ],
            [
              "Q3",
              "315",
              "261"
            ],
            [
              "Q4",
              "324",
              "255"
            ]
          ]
        },
        "chartYAxisTicks": [],
        "subtitle": "Period",
        "yAxisLabel": "Index",
        "barPrimaryColor": "#111111",
        "barSecondaryColor": "#B23B3B",
        "barTertiaryColor": "#2F5C8A"
