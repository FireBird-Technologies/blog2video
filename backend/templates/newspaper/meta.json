  "layout_prop_schema": {
    "news_headline": {
      "label": "News Headline",
      "defaults": {
        "titleFontSize": {
          "portrait": 77,
          "landscape": 68
        },
        "descriptionFontSize": {
          "portrait": 39,
          "landscape": 29
        },
        "category": "News",
        "leftThought": "breakthrough, launch",
        "stats": [
          {
            "value": "By Staff Reporter",
            "label": ""
          },
          {
            "value": "March 2026",
            "label": ""
          }
        ]
      },
      "fields": [
        {
          "key": "titleFontSize",
          "label": "Headline Size",
          "type": "number",
          "responsive": true,
          "min": 18,
          "max": 220,
          "step": 1
