        {
          "key": "leftThought",
          "label": "Highlight Words (comma-separated)",
          "type": "string"
        },
        {
          "key": "stats",
          "label": "Byline Rows",
          "type": "object_array",
          "maxItems": 2,
          "subFields": [
            {
              "key": "value",
              "label": "Value"
            },
            {
              "key": "label",
              "label": "Label (optional)"
            }
          ]
        }
      ]
    },
