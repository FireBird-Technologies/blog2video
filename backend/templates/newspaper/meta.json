{
  "id": "newspaper",
  "name": "Newspaper",
  "new_template": false,
  "popular_template": true,
  "description": "Editorial news-style template with headline cards, article lead, pull quotes, data snapshots, fact-check panels, and timelines.",
  "genres": [
    "Politics",
    "Business",
    "History"
  ],
  "preview_colors": {
    "accent": "#FFE34D",
    "bg": "#FAFAF8",
    "text": "#111111"
  },
  "composition_id": "NewspaperVideo",
  "hero_layout": "news_headline",
  "fallback_layout": "article_lead",
  "valid_layouts": [
    "news_headline",
    "article_lead",
    "pull_quote",
    "data_snapshot",
    "fact_check",
    "news_timeline",
    "data_visualisation",
    "expert_profile",
    "perspective_split",
    "ticker_table",
    "ending_socials"
