      "fields": [
        {
          "key": "titleFontSize",
          "label": "Title Size",
          "type": "number",
          "responsive": true,
          "min": 14,
          "max": 180,
          "step": 1
        },
        {
          "key": "descriptionFontSize",
          "label": "Body Size",
          "type": "number",
          "responsive": true,
          "min": 10,
          "max": 90,
          "step": 1
        },
        {
          "key": "chartType",
          "label": "Chart Type",
          "type": "select",
          "options": [
            {
              "label": "Auto (infer from data)",
              "value": "auto"
            },
            {
              "label": "Line",
              "value": "line"
            },
            {
              "label": "Bar",
              "value": "bar"
            },
            {
              "label": "Histogram",
              "value": "histogram"
            }
          ]
        },
        {
          "key": "chartTable",
          "label": "Chart data — col 1: X labels; cols 2–4: up to 3 numeric series (max 20 data rows). Use bar for named categories; histogram for bins/ranges (0–10, <5, 50+).",
          "type": "chart_table"
        },
        {
          "key": "yAxisLabel",
          "label": "Y-axis label (overrides chart header)",
          "type": "string"
        },
        {
          "key": "subtitle",
          "label": "X-axis / category caption (overrides first column header)",
          "type": "string"
        },
        {
          "key": "chartYAxisTicks",
          "label": "Y-axis tick labels (top → bottom; 2–4 values)",
          "type": "string_array"
        },
        {
          "key": "chartSummary",
          "label": "Chart summary (short read beside the graphic)",
          "type": "string"
        },
        {
          "key": "barPrimaryColor",
          "label": "Series color 1",
          "type": "color"
        },
        {
          "key": "barSecondaryColor",
          "label": "Series color 2",
          "type": "color"
        },
        {
          "key": "barTertiaryColor",
          "label": "Series color 3",
          "type": "color"
        }
      ]
    },
