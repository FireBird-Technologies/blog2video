{
  "id": "newspaper",
  "name": "Newspaper",
  "description": "Editorial news-style template with headline cards, article lead, pull quotes, data snapshots, fact-check panels, and timelines.",
  "styles": [
    "explainer",
    "storytelling"
  ],
  "preview_colors": {
    "accent": "#FFE34D",
    "bg": "#FAFAF8",
    "text": "#111111"
  },
  "composition_id": "NewspaperVideo",
  "hero_layout": "news_headline",
  "fallback_layout": "article_lead",
  "valid_layouts": [
    "news_headline",
    "article_lead",
    "pull_quote",
    "data_snapshot",
    "fact_check",
    "news_timeline"
  ],
  "layout_prop_schema": {
    "news_headline": {
      "label": "News Headline",
      "defaults": {
        "titleFontSize": {
          "portrait": 82,
          "landscape": 78
        },
        "descriptionFontSize": {
          "portrait": 39,
          "landscape": 35
        },
        "category": "News",
        "leftThought": "breakthrough, launch",
        "stats": [
          {
            "value": "By Staff Reporter",
            "label": ""
          },
          {
            "value": "March 2026",
            "label": ""
          }
        ]
      },
      "fields": [
        {
          "key": "titleFontSize",
          "label": "Headline Size",
          "type": "number",
          "responsive": true,
          "min": 18,
          "max": 220,
          "step": 1
        },
        {
          "key": "descriptionFontSize",
          "label": "Subhead Size",
          "type": "number",
          "responsive": true,
          "min": 10,
          "max": 140,
          "step": 1
        },
        {
          "key": "category",
          "label": "Category",
          "type": "string"
        },
        {
          "key": "leftThought",
          "label": "Highlight Words (comma-separated)",
          "type": "string"
        },
        {
          "key": "stats",
          "label": "Byline Rows",
          "type": "object_array",
          "maxItems": 2,
          "subFields": [
            {
              "key": "value",
              "label": "Value"
            },
            {
              "key": "label",
              "label": "Label (optional)"
            }
          ]
        }
      ]
    },
    "article_lead": {
      "label": "Article Lead",
      "defaults": {
        "titleFontSize": {
          "portrait": 84,
          "landscape": 67
        },
        "descriptionFontSize": {
          "portrait": 35,
          "landscape": 30
        },
        "stats": [
          {
            "value": "72",
            "label": "Key stat"
          }
        ]
      },
      "fields": [
        {
          "key": "titleFontSize",
          "label": "Meta Size",
          "type": "number",
          "responsive": true,
          "min": 10,
          "max": 120,
          "step": 1
        },
        {
          "key": "descriptionFontSize",
          "label": "Lead Size",
          "type": "number",
          "responsive": true,
          "min": 10,
          "max": 160,
          "step": 1
        },
        {
          "key": "stats",
          "label": "Pull Stat",
          "type": "object_array",
          "maxItems": 2,
          "subFields": [
            {
              "key": "value",
              "label": "Value"
            },
            {
              "key": "label",
              "label": "Caption"
            }
          ]
        }
      ]
    },
    "pull_quote": {
      "label": "Pull Quote",
      "defaults": {
        "titleFontSize": {
          "portrait": 90,
          "landscape": 71
        },
        "descriptionFontSize": {
          "portrait": 27,
          "landscape": 23
        },
        "stats": [
          {
            "label": "The Editorial Desk",
            "value": ""
          }
        ]
      },
      "fields": [
        {
          "key": "titleFontSize",
          "label": "Quote Size",
          "type": "number",
          "responsive": true,
          "min": 14,
          "max": 200,
          "step": 1
        },
        {
          "key": "descriptionFontSize",
          "label": "Source Size",
          "type": "number",
          "responsive": true,
          "min": 10,
          "max": 120,
          "step": 1
        },
        {
          "key": "stats",
          "label": "Source Row",
          "type": "object_array",
          "maxItems": 1,
          "subFields": [
            {
              "key": "label",
              "label": "Source"
            },
            {
              "key": "value",
              "label": "Value (optional)"
            }
          ]
        }
      ]
    },
    "data_snapshot": {
      "label": "Data Snapshot",
      "defaults": {
        "titleFontSize": {
          "portrait": 78,
          "landscape": 69
        },
        "descriptionFontSize": {
          "portrait": 36,
          "landscape": 22
        },
        "stats": [
          {
            "value": "48%",
            "label": "Increase"
          },
          {
            "value": "2.1M",
            "label": "Readers"
          }
        ]
      },
      "fields": [
        {
          "key": "titleFontSize",
          "label": "Title Size",
          "type": "number",
          "responsive": true,
          "min": 14,
          "max": 220,
          "step": 1
        },
        {
          "key": "descriptionFontSize",
          "label": "Card Label Size",
          "type": "number",
          "responsive": true,
          "min": 10,
          "max": 120,
          "step": 1
        },
        {
          "key": "stats",
          "label": "Key Figures",
          "type": "object_array",
          "maxItems": 6,
          "subFields": [
            {
              "key": "value",
              "label": "Value"
            },
            {
              "key": "label",
              "label": "Label"
            }
          ]
        }
      ]
    },
    "fact_check": {
      "label": "Fact Check",
      "defaults": {
        "titleFontSize": {
          "portrait": 70,
          "landscape": 64
        },
        "descriptionFontSize": {
          "portrait": 30,
          "landscape": 25
        },
        "leftThought": "Claim being made",
        "rightThought": "Evidence-based correction",
        "stats": [
          {
            "label": "Claimed",
            "value": ""
          },
          {
            "label": "Facts",
            "value": ""
          }
        ]
      },
      "fields": [
        {
          "key": "titleFontSize",
          "label": "Title Size",
          "type": "number",
          "responsive": true,
          "min": 14,
          "max": 220,
          "step": 1
        },
        {
          "key": "descriptionFontSize",
          "label": "Panel Text Size",
          "type": "number",
          "responsive": true,
          "min": 10,
          "max": 140,
          "step": 1
        },
        {
          "key": "leftThought",
          "label": "Claimed",
          "type": "text"
        },
        {
          "key": "rightThought",
          "label": "Facts",
          "type": "text"
        },
        {
          "key": "stats",
          "label": "Column Labels",
          "type": "object_array",
          "maxItems": 2,
          "subFields": [
            {
              "key": "label",
              "label": "Label"
            },
            {
              "key": "value",
              "label": "Value (optional)"
            }
          ]
        }
      ]
    },
    "news_timeline": {
      "label": "News Timeline",
      "defaults": {
        "titleFontSize": {
          "portrait": 76,
          "landscape": 62
        },
        "descriptionFontSize": {
          "portrait": 26,
          "landscape": 23
        },
        "stats": [
          {
            "value": "Jan 2025",
            "label": "Event begins"
          },
          {
            "value": "Jul 2025",
            "label": "Milestone reached"
          },
          {
            "value": "Jan 2026",
            "label": "Outcome announced"
          }
        ]
      },
      "fields": [
        {
          "key": "titleFontSize",
          "label": "Title Size",
          "type": "number",
          "responsive": true,
          "min": 14,
          "max": 220,
          "step": 1
        },
        {
          "key": "descriptionFontSize",
          "label": "Timeline Text Size",
          "type": "number",
          "responsive": true,
          "min": 10,
          "max": 140,
          "step": 1
        },
        {
          "key": "stats",
          "label": "Timeline Events",
          "type": "object_array",
          "maxItems": 8,
          "subFields": [
            {
              "key": "value",
              "label": "Date"
            },
            {
              "key": "label",
              "label": "Description"
            }
          ]
        }
      ]
    }
  },
  "layouts_without_image": [
    "pull_quote",
    "data_snapshot"
  ],
  "features": [
    "News headline hero with category and byline",
    "Article lead with drop cap and pull stat",
    "Pull quote with attribution",
    "Data snapshot cards with key figures",
    "Fact-check claim vs facts layout",
    "News timeline with spine and dates",
    "Portrait and landscape responsive layout"
  ]
}
