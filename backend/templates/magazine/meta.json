      "label": "Magazine Cover",
      "defaults": {
        "titleFontSize": {
          "portrait": 92,
          "landscape": 76
        },
        "descriptionFontSize": {
          "portrait": 52,
          "landscape": 40
        }
      },
      "fields": [
        {
          "key": "titleFontSize",
          "label": "Title Font Size",
          "type": "number",
          "responsive": true,
          "min": 18,
          "max": 220,
          "step": 1
        },
        {
          "key": "descriptionFontSize",
          "label": "Body Font Size",
          "type": "number",
          "responsive": true,
