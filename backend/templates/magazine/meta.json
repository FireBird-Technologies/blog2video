    "feature_spread": {
      "label": "Feature Spread",
      "defaults": {
        "titleFontSize": {
          "portrait": 92,
          "landscape": 56
        },
        "descriptionFontSize": {
          "portrait": 52,
          "landscape": 28
        },
        "sectionLabel": "FEATURE"
      },
      "scene_defaults": {
        "title": "The Shape of Things to Come",
        "narration": "On a wet Tuesday in a converted east-London warehouse, eleven people are arguing about a margin. It is four millimetres wide, and it has held up the issue for an hour. To an outsider the fuss looks absurd; to the people in the room it is the entire job. This is one of a dozen small studios betting that how a thing is made still matters — that the gap between good and merely adequate is paid for in exactly these arguments. Get the four millimetres right, they say, and the reader never notices a thing. Get them wrong, and no amount of ornament will save the page.",
        "durationSeconds": 7
      },
      "sample_props": {
        "sectionLabel": "FEATURE",
        "body": "On a wet Tuesday in a converted east-London warehouse, eleven people are arguing about a margin. It is four millimetres wide, and it has held up the issue for an hour. To an outsider the fuss looks absurd; to the people in the room it is the entire job. This is one of a dozen small studios betting that how a thing is made still matters — that the gap between good and merely adequate is paid for in exactly these arguments. Get the four millimetres right, they say, and the reader never notices a thing. Get them wrong, and no amount of ornament will save the page.",
        "keyPoints": [
          {
            "value": "Attention is the scarce resource"
          },
          {
            "value": "Detail is the whole job"
          },
          {
            "value": "Craft outlasts ornament"
          }
        ]
      },
      "fields": [
        {
          "key": "titleFontSize",
          "label": "Title Font Size",
          "type": "number",
          "responsive": true,
          "min": 18,
          "max": 220,
