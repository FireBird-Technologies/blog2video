    "interview_qa": {
      "label": "Interview Q&A",
      "defaults": {
        "titleFontSize": {
          "portrait": 92,
          "landscape": 76
        },
        "descriptionFontSize": {
          "portrait": 52,
          "landscape": 40
        }
      },
      "scene_defaults": {
        "title": "Where does a redesign actually begin?",
        "narration": "We sat down with the team behind the redesign.",
        "durationSeconds": 8
      },
      "sample_props": {
        "leftSpeaker": "Mara Voss",
        "rightSpeaker": "Art Director",
        "exchanges": [
          {
            "q": "Where does a redesign actually begin?",
            "a": "It begins long before anything is drawn. We spent weeks simply reading the old magazine, page by page, asking where the eye stalled and where it flew. Only once we understood how people moved through it did we touch the grid."
          },
          {
            "q": "What was the hardest constraint?",
            "a": "Type, always. A magazine lives or dies on its body text, and the temptation is to make it expressive. We resisted that — the headline can sing, but the body must disappear into the reading."
          },
          {
            "q": "How do you know when it's finished?",
            "a": "You never quite do. But there's a moment when a spread stops feeling designed and starts feeling inevitable, as if it could not have been any other way. That is the signal to stop."
          }
        ]
      },
      "fields": [
        {
          "key": "titleFontSize",
          "label": "Title Font Size",
          "type": "number",
          "responsive": true,
          "min": 18,
          "max": 220,
          "step": 1
        },
        {
          "key": "descriptionFontSize",
