    "magazine_data_visualization": {
      "label": "Data Visualisation",
      "defaults": {
        "titleFontSize": {
          "portrait": 56,
          "landscape": 52
        },
        "descriptionFontSize": {
          "portrait": 28,
          "landscape": 26
        },
        "chartType": "line",
        "chartSummary": "Readership climbed steadily across the period before levelling off near the high.",
        "chartTable": {
          "headers": [
            "Quarter",
            "Readers",
            "Subscribers"
          ],
          "rows": [
            ["Q1", "298", "72"],
            ["Q2", "308", "68"],
            ["Q3", "315", "61"],
            ["Q4", "324", "55"],
            ["Q5", "318", "59"]
          ]
        },
        "chartYAxisTicks": [],
        "subtitle": "Quarter",
        "yAxisLabel": "Thousands",
        "barPrimaryColor": "#D71921",
        "barSecondaryColor": "#111111"
      },
      "scene_defaults": {
        "title": "The story in the numbers",
        "narration": "The figures tell their own story across the period.",
        "durationSeconds": 7
      },
      "fields": [
        {
          "key": "titleFontSize",
          "label": "Title Size",
          "type": "number",
          "responsive": true,
          "min": 14,
          "max": 160,
          "step": 1
        },
        {
          "key": "descriptionFontSize",
          "label": "Body Size",
          "type": "number",
          "responsive": true,
          "min": 10,
          "max": 90,
          "step": 1
        },
        {
          "key": "chartType",
          "label": "Chart Type",
          "type": "select",
          "options": [
            { "label": "Auto (infer from data)", "value": "auto" },
            { "label": "Line", "value": "line" },
            { "label": "Bar", "value": "bar" },
            { "label": "Histogram", "value": "histogram" }
          ]
        },
        {
          "key": "chartTable",
          "label": "Chart data — col 1: X labels; cols 2–4: up to 3 numeric series (max 20 data rows). Use bar for named categories; histogram for bins/ranges (0–10, <5, 50+).",
          "type": "chart_table"
        },
        {
          "key": "yAxisLabel",
          "label": "Y-axis label (overrides chart header)",
          "type": "string"
        },
        {
          "key": "subtitle",
          "label": "X-axis / category caption (overrides first column header)",
          "type": "string"
        },
        {
          "key": "chartYAxisTicks",
          "label": "Y-axis tick labels (top → bottom; 2–4 values)",
          "type": "string_array"
        },
        {
          "key": "chartSummary",
          "label": "Chart summary (short read beside the graphic)",
          "type": "string"
        },
        {
          "key": "barPrimaryColor",
          "label": "Series color 1",
          "type": "color"
        },
        {
          "key": "barSecondaryColor",
          "label": "Series color 2",
          "type": "color"
        }
      ]
