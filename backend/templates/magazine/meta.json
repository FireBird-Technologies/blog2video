{
  "id": "magazine",
  "name": "Magazine",
  "new_template": true,
  "description": "An authentic print-editorial magazine template: cream paper, serif headlines and book-serif body, a single red accent, hairline rules, page folios and a masthead. Purely typographic — no photographs. Folios, kicker labels, pull quotes, Q&A blocks and crisp infographic ledgers for features, interviews and brand content.",
  "genres": [
    "Business",
    "Lifestyle",
    "Technology",
    "Culture"
  ],
  "preview_colors": {
    "accent": "#D71921",
    "bg": "#FFFFFF",
    "text": "#111111"
  },
  "composition_id": "MagazineVideo",
  "hero_layout": "magazine_cover",
  "fallback_layout": "feature_spread",
  "valid_layouts": [
    "magazine_cover",
    "feature_spread",
    "editorial_quote",
    "photo_essay",
    "by_the_numbers",
    "interview_qa",
    "comparison_spread",
    "magazine_data_visualization",
    "timeline_journey",
    "expert_spotlight",
    "text_narration",
    "ending_socials",
    "magazine_ticker"
  ],
  "layout_prop_schema": {
