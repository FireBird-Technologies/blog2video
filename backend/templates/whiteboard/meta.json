    "handwritten_equation": {
      "label": "Handwritten Equation",
      "scene_defaults": {
        "title": "The Formula",
        "narration": "Breaking it down step by step"
      },
      "defaults": {
        "titleFontSize": {
          "portrait": 80,
          "landscape": 68
        },
        "descriptionFontSize": {
          "portrait": 32,
          "landscape": 27
        },
        "stats": [
          {
            "label": "Compound Interest Formula",
            "value": "A = P · (1 + r/n)^(n·t)"
          },
          {
            "label": "Where:",
            "value": "P = principal,  r = rate,  n = compounds/yr"
          },
          {
            "label": "Example:",
            "value": "A = 1000 · (1 + 0.05/12)^(12·5)"
          },
          {
            "label": "Result:",
            "value": "A ≈ $1,283.36"
          }
