    "pros_cons": {
      "label": "Pros & Cons",
      "defaults": {
        "titleFontSize": {
          "portrait": 56,
          "landscape": 60
        },
        "descriptionFontSize": {
          "portrait": 24,
          "landscape": 22
        },
        "sectionLabel": "LEADERS",
        "prosLabel": "PROS",
        "consLabel": "CONS",
        "intro": "On June 18th America's central bank will take what may prove a historic decision: the first interest-rate cut since the tightening cycle began. The data crunch is genuine, and the consequences will be profound. Here are the arguments for and against easing now.",
        "pros": [
          {
            "lead": "GROWTH IS COOLING",
            "body": "Hiring has slowed and manufacturing output has contracted for three straight months."
          },
          {
            "lead": "INFLATION NEAR TARGET",
            "body": "Core PCE has drifted to 2.4%, within touching distance of the 2% goal."
          },
          {
            "lead": "REAL RATES ARE HIGH",
            "body": "With prices easing, the inflation-adjusted policy rate is the most restrictive since 2007."
          }
        ],
        "cons": [
          {
            "lead": "SERVICES STAY HOT",
            "body": "Wage growth in services remains above 4%, keeping underlying inflation sticky."
          },
          {
            "lead": "CONDITIONS ALREADY EASY",
            "body": "Buoyant equities and tight credit spreads are doing much of the Fed's work already."
          },
          {
            "lead": "CREDIBILITY AT STAKE",
            "body": "Cutting too soon risks a second wave of inflation the bank has vowed to avoid."
          }
        ]
      },
      "fields": [
        {
          "key": "titleFontSize",
          "label": "Headline Size",
          "type": "number",
          "responsive": true,
          "min": 28,
          "max": 120,
          "step": 1
        },
        {
          "key": "intro",
          "label": "Intro Paragraph",
          "type": "text",
          "placeholder": "Short justified intro"
        },
        {
          "key": "prosLabel",
          "label": "Left Column Header",
          "type": "string",
          "placeholder": "PROS"
        },
        {
          "key": "consLabel",
          "label": "Right Column Header",
          "type": "string",
          "placeholder": "CONS"
        },
        {
          "key": "pros",
          "label": "Pros (3-6)",
          "type": "object_array",
          "maxItems": 6,
          "subFields": [
            {
              "key": "lead",
              "label": "Lead-in"
            },
            {
              "key": "body",
              "label": "Explanation"
            }
          ]
        },
        {
          "key": "cons",
          "label": "Cons (3-6)",
          "type": "object_array",
          "maxItems": 6,
          "subFields": [
            {
              "key": "lead",
              "label": "Lead-in"
            },
            {
              "key": "body",
              "label": "Explanation"
            }
