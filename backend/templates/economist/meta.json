  "features": [
    "Warm-paper editorial aesthetic with a red flag masthead (homage, not a copy)",
    "Premium cinematic magazine-cover intro with parallax photo and teaser headlines",
    "Reference-grade custom line charts: right-side axis, emphasised black zero line, direct colour-coded end-labels, grey context lines, and a boxed panel number",
    "Ranked bar charts (vertical and horizontal) with staggered grow-in",
    "Ranked data tables with inline red magnitude bars",
    "Signature blue PROS / red CONS debate page",
    "By-the-numbers KPI panels with trend arrows",
    "Oversized red pull-quotes with highlighted phrases",
    "Full-bleed photo features with caption and credit",
    "Serif headlines with drop caps and justified article body",
    "Kinetic editorial scene transitions — parallax page-push, whip-blur, clock-wipe, iris and a branded ink-bar wipe",
    "Portrait and landscape responsive layouts"
  ]
}
