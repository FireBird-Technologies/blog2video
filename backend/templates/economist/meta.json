{
  "id": "economist",
  "name": "The Economist",
  "new_template": true,
  "description": "Editorial 'newspaper × economic article' template inspired by The Economist: warm paper, a red flag masthead, serif headlines with drop caps, a signature blue/red pros-and-cons page, and reference-grade custom data charts (right-axis line charts with direct end-labels, ranked bars, ranked tables). Perfect for finance, markets, economics and serious news explainers.",
  "genres": [
    "Finance",
    "Business",
    "News"
  ],
  "preview_colors": {
    "accent": "#E3120B",
    "bg": "#F6F4EE",
    "text": "#1A1A1A"
  },
  "composition_id": "EconomistVideo",
  "hero_layout": "cover_reveal",
  "fallback_layout": "leader_article",
  "valid_layouts": [
    "cover_reveal",
    "leader_article",
    "section_divider",
    "chart_line",
    "chart_bar",
    "data_table",
    "pros_cons",
    "key_indicators",
    "leader_quote",
    "image_feature",
    "ending_socials"
  ],
  "layout_prop_schema": {
    "cover_reveal": {
      "label": "Cover Reveal (Intro)",
      "defaults": {
        "titleFontSize": {
          "portrait": 104,
          "landscape": 132
        },
        "descriptionFontSize": {
          "portrait": 30,
          "landscape": 26
        },
        "dateline": "MAY 23RD–29TH 2026",
        "teasers": [
          "We calculate the MAGA tax",
          "Lessons from the Premier League",
          "NATO: time for Plan B",
          "Are economists amoral?"
        ]
      },
      "fields": [
        {
          "key": "titleFontSize",
          "label": "Headline Size",
          "type": "number",
          "responsive": true,
          "min": 40,
          "max": 240,
          "step": 1
        },
        {
          "key": "dateline",
          "label": "Dateline",
          "type": "string",
          "placeholder": "MAY 23RD–29TH 2026"
        },
        {
          "key": "teasers",
          "label": "Contents Teasers (3-4)",
          "type": "string_array",
          "maxItems": 4
        }
      ]
    },
    "leader_article": {
      "label": "Leader Article",
      "defaults": {
        "titleFontSize": {
          "portrait": 68,
          "landscape": 82
        },
        "descriptionFontSize": {
          "portrait": 32,
          "landscape": 30
        },
        "sectionLabel": "BRIEFING",
        "byline": "By our finance correspondent"
      },
      "fields": [
        {
          "key": "titleFontSize",
          "label": "Headline Size",
          "type": "number",
          "responsive": true,
          "min": 28,
          "max": 140,
          "step": 1
        },
        {
          "key": "descriptionFontSize",
          "label": "Body Size",
          "type": "number",
          "responsive": true,
          "min": 14,
          "max": 60,
          "step": 1
        },
        {
          "key": "sectionLabel",
          "label": "Section Kicker",
          "type": "string",
          "placeholder": "BRIEFING"
        },
        {
          "key": "byline",
          "label": "Byline",
          "type": "string",
          "placeholder": "By our correspondent"
        },
        {
          "key": "illuminatedLetter",
          "label": "Drop Cap Override",
          "type": "string",
          "placeholder": "Auto"
        }
      ]
    },
    "section_divider": {
      "label": "Section Divider",
      "defaults": {
        "titleFontSize": {
          "portrait": 120,
          "landscape": 156
        },
        "descriptionFontSize": {
          "portrait": 28,
          "landscape": 26
        },
        "sectionLabel": "SECTION",
        "standfirst": "Why the world's central banks are quietly changing course",
        "dateline": "MAY 23RD–29TH 2026"
