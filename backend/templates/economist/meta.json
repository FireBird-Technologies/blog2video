        {
          "key": "standfirst",
          "label": "Standfirst",
          "type": "text",
          "placeholder": "Short standfirst under the section name"
        },
        {
          "key": "dateline",
          "label": "Dateline",
          "type": "string",
          "placeholder": "MAY 23RD–29TH 2026"
        }
      ]
    },
