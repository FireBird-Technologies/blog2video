  "features": [
    "Medieval tome aesthetic with parchment texture, dust motes, and candle-glow vignette",
    "Opening book intro with cracking wax seal and page-flip",
    "Illuminated drop caps and quill-written text reveals",
    "Embossed sepia image cards with torn-paper treatment",
    "Heraldic banner title cards for section breaks",
    "Wax-seal stamps with dust-puff impact",
    "Red-ribbon banner attributions",
    "Unfurled cartographer's map image treatment with compass rose",
    "Blackletter decree word with punch-in seal",
    "Timeline waypoints drawn in ink",
    "Versus folios with central 'vs.' medallion",
    "Page-turn transitions between every scene",
    "Portrait and landscape responsive layouts"
  ]
}
