{
  "id": "chronicle",
  "name": "Chronicle",
  "new_template": true,
  "description": "Old history-book tome with parchment pages, illuminated drop caps, wax seals and quill-written text. Perfect for history, heritage, mythology and long-form storytelling.",
  "styles": [
    "storytelling",
    "explainer"
  ],
  "preview_colors": {
    "accent": "#B8860B",
    "bg": "#F1E4C9",
    "text": "#2A1810"
  },
  "composition_id": "ChronicleVideo",
  "hero_layout": "book_open",
  "fallback_layout": "parchment_scroll",
  "valid_layouts": [
    "book_open",
    "parchment_scroll",
    "chapter_plate",
    "illuminated_quote",
    "ledger_stats",
    "versus_folio",
    "chronicle_timeline",
    "map_reveal",
    "decree_seal",
    "ending_socials"
  ],
  "layout_prop_schema": {
    "book_open": {
      "label": "Book Open (Intro)",
      "defaults": {
        "titleFontSize": {
          "portrait": 92,
          "landscape": 96
        },
        "descriptionFontSize": {
          "portrait": 34,
          "landscape": 30
        },
        "hideImage": true
      },
      "fields": [
        {
          "key": "titleFontSize",
          "label": "Title Size",
          "type": "number",
          "responsive": true,
          "min": 24,
          "max": 220,
          "step": 1
        },
        {
          "key": "descriptionFontSize",
          "label": "Subtitle Size",
          "type": "number",
          "responsive": true,
          "min": 12,
          "max": 120,
          "step": 1
        }
      ]
    },
    "parchment_scroll": {
      "label": "Parchment Scroll",
      "defaults": {
        "titleFontSize": {
          "portrait": 66,
          "landscape": 62
        },
        "descriptionFontSize": {
          "portrait": 34,
          "landscape": 28
        },
        "category": "",
        "illuminatedLetter": "",
        "stats": []
      },
      "fields": [
        {
          "key": "titleFontSize",
          "label": "Heading Size",
          "type": "number",
          "responsive": true,
          "min": 14,
          "max": 220,
          "step": 1
        },
        {
          "key": "descriptionFontSize",
          "label": "Body Size",
          "type": "number",
          "responsive": true,
          "min": 10,
          "max": 120,
          "step": 1
        },
        {
          "key": "category",
          "label": "Section Tag",
          "type": "string"
        },
        {
          "key": "illuminatedLetter",
          "label": "Drop Cap Letter (optional)",
          "type": "string",
          "placeholder": "Auto from first letter"
        },
        {
          "key": "stats",
          "label": "Byline (optional)",
          "type": "object_array",
          "maxItems": 2,
          "subFields": [
            { "key": "value", "label": "Value" },
            { "key": "label", "label": "Label" }
          ]
        }
      ]
    },
    "chapter_plate": {
      "label": "Heraldic Banner",
      "defaults": {
        "titleFontSize": {
          "portrait": 72,
          "landscape": 66
        },
        "descriptionFontSize": {
          "portrait": 32,
          "landscape": 28
        },
        "subtitle": "",
        "hideImage": true
      },
      "fields": [
        {
          "key": "titleFontSize",
          "label": "Banner Title Size",
          "type": "number",
          "responsive": true,
          "min": 24,
          "max": 240,
          "step": 1
