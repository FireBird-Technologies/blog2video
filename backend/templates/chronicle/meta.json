        {
          "key": "subtitle",
          "label": "Kicker above title (optional)",
          "type": "string",
          "placeholder": "e.g. Act One, The Founding Years"
        }
      ]
    },
    "illuminated_quote": {
      "label": "Illuminated Quote",
