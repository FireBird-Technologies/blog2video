{
  "id": "sakura",
  "name": "Sakura",
  "new_template": true,
  "description": "A deeply characterful Japanese-aesthetic template featuring washi paper textures, Seigaiha wave patterns, Kamon crests, and falling cherry blossom petals. Ideal for converting written content into narrated, branded videos.",
  "genres": [
    "blog",
    "editorial",
    "cultural",
    "storytelling",
    "lifestyle"
  ],
  "preview_colors": {
    "accent": "#C0143C",
    "bg": "#FDF6F0",
    "text": "#2A0A12"
  },
  "composition_id": "SakuraVideo",
  "hero_layout": "sakura_intro",
  "fallback_layout": "sakura_section",
  "valid_layouts": [
    "sakura_intro",
    "sakura_section",
    "sakura_quote",
    "sakura_two_column_detail",
    "sakura_stat_highlight",
    "sakura_list_scene",
    "sakura_text_narration",
    "sakura_image_focus",
    "sakura_chapter_transition",
    "sakura_ending_socials"
  ],
